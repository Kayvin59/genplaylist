# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (required) — used for AI-powered track extraction
OPENAI_API_KEY=sk-your-openai-key

# Firecrawl (optional) — if not set, built-in Cheerio scraper is used
# FIRECRAWL_API_KEY=fc-your-firecrawl-key

# Upstash Redis (required) — used for rate limiting
# Auto-populated by Vercel Upstash integration, or set manually from https://console.upstash.com
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=your-redis-token

# Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_VALUE_PRICE_ID=price_...
STRIPE_POWER_PRICE_ID=price_...

# Site URL (optional) — defaults to localhost in dev, VERCEL_URL in production
# NEXT_PUBLIC_SITE_URL=https://gen-playlist.vercel.app
